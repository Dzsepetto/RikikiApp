<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="RikikiApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:RikikiApp"
    xmlns:views="clr-namespace:RikikiApp.Views"
    Title="RikikiApp">
    <TabBar>
        <Tab Title="Profile" Icon="user_icon.svg">
            <ShellContent ContentTemplate="{DataTemplate views:ProfilePage}" Route="ProfilePage" />
        </Tab>
        <Tab Title="Home" Icon="home_icon.svg">
            <ShellContent ContentTemplate="{DataTemplate views:MainPage}" Route="MainPage" />
        </Tab>
        <Tab Title="Stats" Icon="stats_icon.svg">
            <ShellContent ContentTemplate="{DataTemplate views:StatsPage}" Route="StatsPage" />
        </Tab>
        
    </TabBar>
</Shell>
