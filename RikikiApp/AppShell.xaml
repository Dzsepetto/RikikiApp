<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="RikikiApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:RikikiApp"
    xmlns:views="clr-namespace:RikikiApp.Views"
    Title="RikikiApp"
    FlyoutBehavior="Disabled">

    <ShellContent 
        Route="MainLayoutPage"
        ContentTemplate="{DataTemplate views:MainLayoutPage}" />

    <ShellContent Route="MainPage" ContentTemplate="{DataTemplate views:MainPage}" />
    <ShellContent Route="ProfilePage" ContentTemplate="{DataTemplate views:ProfilePage}" />
    <ShellContent Route="StatsPage" ContentTemplate="{DataTemplate views:StatsPage}" />
    
</Shell>
