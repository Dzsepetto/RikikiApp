<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:RikikiApp.Converters"
             x:Class="RikikiApp.Views.GameView"
             x:Name="Root">
    
    <ContentView.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColor" />
    </ContentView.Resources>
    
    <Grid Padding="12" RowDefinitions="Auto,*">
        <Grid ColumnDefinitions="Auto,Auto,Auto" Row="0" ColumnSpacing="20" HorizontalOptions="Center">
            <Button Text="Back" Command="{Binding BackCommand}" Grid.Column="0"/>

            <Label Text="Games"
                   Grid.Column="1"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   FontSize="18"
                   FontAttributes="Bold" />

            <Button Text="New Game" Command="{Binding NewGameCommand}" Grid.Column="2"/>
        </Grid>

        <VerticalStackLayout Grid.Row="1" Spacing="10" Padding="0,16,0,0">
            <Label Text="{Binding GamesTitle}" FontAttributes="Bold" TextColor="Black" />
            <Label Text="Filters: "/>
            <Grid ColumnDefinitions="Auto,Auto,Auto" Padding="10,0,10,0" HorizontalOptions="Center" ColumnSpacing="20">

                <Button Text="Setup" Grid.Column="0"
                Command="{Binding ToggleSetupCommand}"
                BackgroundColor="{Binding IsSetupSelected, Converter={StaticResource BoolToColor}}" />

                        <Button Grid.Column="1"
                Text="In Progress"
                Command="{Binding ToggleInProgressCommand}"
                BackgroundColor="{Binding IsInProgressSelected, Converter={StaticResource BoolToColor}}" />

                        <Button Grid.Column="2"
                Text="Finished"
                Command="{Binding ToggleFinishedCommand}"
                BackgroundColor="{Binding IsFinishedSelected, Converter={StaticResource BoolToColor}}" />

            </Grid>
            <CollectionView ItemsSource="{Binding Games}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <Label Text="No games yet. Tap + New to create one."
                           Opacity="0.7" />
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeThickness="1"
                Padding="10"
                Margin="0,6">

                            <Grid ColumnDefinitions="*,Auto">

                                <VerticalStackLayout>
                                    <Label Text="{Binding Name}"
                           FontAttributes="Bold" />

                                    <Label Text="{Binding Status}"
                           FontSize="12"
                           Opacity="0.7"/>
                                </VerticalStackLayout>

                                <Button Grid.Column="1" Text="Open"
                                       Command="{Binding Source={x:Reference Root}, Path=BindingContext.OpenGameCommand}"
                                        CommandParameter="{Binding Id}" />

                            </Grid>

                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </Grid>
</ContentView>