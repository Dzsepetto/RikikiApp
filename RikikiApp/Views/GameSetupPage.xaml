<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RikikiApp.Views.GameSetupPage"
             Shell.NavBarIsVisible="False">

    <Grid Padding="12" RowDefinitions="Auto,*,Auto">

        <Grid ColumnDefinitions="Auto,*,Auto" Row="0">
            <Button Text="← Back"
            Clicked="OnBackClicked"
            HorizontalOptions="Start" />

            <Label x:Name="TitleLabel"
           Grid.Column="1"
           HorizontalOptions="Center"
           VerticalOptions="Center"
           FontSize="18"
           FontAttributes="Bold" />

            <Button Text="🗑"
            Grid.Column="2"
            Clicked="OnDeleteClicked"
            HorizontalOptions="End" />
        </Grid>

        <VerticalStackLayout Grid.Row="1" Spacing="14" Padding="0,16,0,0">

            <Label Text="Players" FontAttributes="Bold" />

            <CollectionView x:Name="PlayersList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*,Auto,Auto" Padding="6" ColumnSpacing="10">

                            <!-- Name -->
                            <Label
                            Text="{Binding GuestName}"
                            FontAttributes="Bold"
                            VerticalOptions="Center"/>

                                            <!-- Seat -->
                           <Label
                            Grid.Column="1"
                            Text="{Binding SeatOrder, StringFormat='Seat {0}'}"
                            VerticalOptions="Center"/>

                            <Button
                            Grid.Column="2"
                            Text="✕"
                            WidthRequest="40"
                            HeightRequest="40"
                            BackgroundColor="Transparent"
                            TextColor="Red"
                            Clicked="OnDeletePlayerClicked"
                            CommandParameter="{Binding .}" />

                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="+ Add player" Clicked="OnAddPlayerClicked" />

            <Label Text="Scoring version" FontAttributes="Bold" />
            <Picker x:Name="ScoringPicker" />

        </VerticalStackLayout>

        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,12,0,0">

            <Button Grid.Column="0"
            x:Name="EndGameButton"
            Text="End game"
            BackgroundColor="Red"
            TextColor="White"
            Clicked="OnEndGameClicked"/>

            <Button Grid.Column="1"
            x:Name="StartGameButton"
            Text="Start game"
            BackgroundColor="Green"
            Clicked="OnStartGameClicked"/>
        </Grid>
    </Grid>
</ContentPage>