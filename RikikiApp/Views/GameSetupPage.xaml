<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RikikiApp.Views.GameSetupPage"
             Shell.NavBarIsVisible="False">

    <Grid Padding="12" RowDefinitions="Auto,*,Auto">

        <Grid ColumnDefinitions="Auto,*,Auto" Row="0">
            <Button Text="← Back"
                    Clicked="OnBackClicked"
                    HorizontalOptions="Start" />

            <Label x:Name="TitleLabel"
                   Grid.Column="1"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   FontSize="18"
                   FontAttributes="Bold" />

            <Button Text="🗑"
                    Grid.Column="2"
                    Clicked="OnDeleteClicked"
                    HorizontalOptions="End" />
        </Grid>

        <VerticalStackLayout Grid.Row="1" Spacing="14" Padding="0,16,0,0">

            <Label Text="Players" FontAttributes="Bold" />

            <CollectionView x:Name="PlayersList"
                            ItemsLayout="VerticalList"
                            Margin="0,6">

                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Grid ColumnDefinitions="40,50,*,50"
                              Padding="8"
                              VerticalOptions="Center">

                            <!-- DROP TARGET -->
                            <Grid.GestureRecognizers>
                                <DropGestureRecognizer AllowDrop="True"
                                                       Drop="OnDrop"/>
                            </Grid.GestureRecognizers>

                            <!-- DRAG HANDLE -->
                            <Label Text="☰"
                                   FontSize="18"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center">
                            </Label>

                            <!-- SEAT -->
                            <Border Grid.Column="1"
                                    BackgroundColor="#E8E8E8"
                                    StrokeThickness="0"
                                    Padding="6"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>

                                <Label Text="{Binding SeatOrder}"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>

                            <!-- PLAYER NAME -->
                            <Label Grid.Column="2"
                                   Text="{Binding GuestName}"
                                   FontSize="16"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Start"/>

                            <!-- DELETE -->
                            <Button Grid.Column="3"
                                    Text="🗑"
                                    CommandParameter="{Binding .}"
                                    Clicked="OnDeletePlayerClicked"
                                    BackgroundColor="Transparent"
                                    HorizontalOptions="End"/>

                        </Grid>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

            <Button Text="+ Add player"
                    Clicked="OnAddPlayerClicked" />

            <Label Text="Scoring version" FontAttributes="Bold" />
            <Picker x:Name="ScoringPicker" />

        </VerticalStackLayout>

        <Grid Grid.Row="2"
              ColumnDefinitions="*,*"
              ColumnSpacing="10"
              Margin="0,12,0,0">

            <Button Grid.Column="0"
                    x:Name="EndGameButton"
                    Text="End game"
                    BackgroundColor="Red"
                    TextColor="White"
                    Clicked="OnEndGameClicked"/>

            <Button Grid.Column="1"
                    x:Name="StartGameButton"
                    Text="Start game"
                    BackgroundColor="Green"
                    Clicked="OnStartGameClicked"/>

        </Grid>

    </Grid>

</ContentPage>