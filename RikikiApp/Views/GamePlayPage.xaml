<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="RikikiApp.Views.GamePlayPage"
    Shell.NavBarIsVisible="False">

    <Grid Padding="20" RowDefinitions="Auto,*">

        <!-- HEADER -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" VerticalOptions="Center">

            <Button
                Text="←"
                Clicked="OnBackClicked"
                WidthRequest="40"
                HeightRequest="40"
                BackgroundColor="blue"
                FontSize="18" />

            <Label
                Grid.Column="1"
                x:Name="RoundLabel"
                FontSize="22"
                FontAttributes="Bold"
                VerticalOptions="Center"
                HorizontalTextAlignment="Center"/>

        </Grid>

        <!-- CONTENT -->
        <ScrollView Grid.Row="1">

            <Grid RowDefinitions="*,Auto">

                <!-- GAME -->
                <VerticalStackLayout 
                    x:Name="GameSection" 
                    Spacing="16"
                    VerticalOptions="Center">

                    <CollectionView x:Name="CallsList">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>

                                <Grid ColumnDefinitions="*,120,120" Padding="8">

                                    <Label
                                        Text="{Binding PlayerName}"
                                        VerticalOptions="Center" />

                                    <!-- CALL -->
                                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                                        <Stepper
                                            Minimum="0"
                                            Maximum="{Binding MaxValue}"
                                            Increment="1"
                                            Value="{Binding Called, Mode=TwoWay}"
                                            IsEnabled="{Binding IsCallEnabled}" />

                                        <Label
                                            Text="{Binding Called}"
                                            HorizontalOptions="Center" />
                                    </VerticalStackLayout>

                                    <!-- WON -->
                                    <VerticalStackLayout Grid.Column="2" Spacing="4"
                                                         IsVisible="{Binding IsWonVisible}">
                                        <Stepper
                                            Minimum="0"
                                            Maximum="{Binding MaxValue}"
                                            Increment="1"
                                            Value="{Binding Won, Mode=TwoWay}"
                                            IsEnabled="{Binding IsWonEnabled}" />

                                        <Label
                                            Text="{Binding Won}"
                                            HorizontalOptions="Center" />
                                    </VerticalStackLayout>

                                </Grid>

                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </VerticalStackLayout>

                <!-- RESULTS -->
                <VerticalStackLayout
                    x:Name="ResultSection"
                    IsVisible="False"
                    Spacing="12"
                    VerticalOptions="Center"
                    HorizontalOptions="Center">

                    <Label
                        Text="Round Results"
                        FontSize="18"
                        FontAttributes="Bold"
                        HorizontalOptions="Center" />

                    <CollectionView
                        x:Name="ResultsList"
                        WidthRequest="300"
                        HeightRequest="250">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>

                                <Grid ColumnDefinitions="*,60,60,80" Padding="6">

                                    <Label Text="{Binding PlayerName}" />
                                    <Label Grid.Column="1" Text="{Binding Called}" />
                                    <Label Grid.Column="2" Text="{Binding Won}" />
                                    <Label Grid.Column="3" Text="{Binding Score}" FontAttributes="Bold" />

                                </Grid>

                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </VerticalStackLayout>

                <!-- BUTTONS -->
                <Grid Grid.Row="1">

                    <VerticalStackLayout x:Name="GameButtons" Spacing="10">

                        <Button
                            x:Name="FixCallsButton"
                            Text="Fix Calls"
                            Clicked="OnFixCallsClicked"
                            BackgroundColor="Blue"
                            TextColor="White" />

                        <Button
                            x:Name="EndRoundButton"
                            Text="End Round"
                            Clicked="OnEndRoundClicked"
                            BackgroundColor="Green"
                            TextColor="White"
                            IsVisible="False" />

                    </VerticalStackLayout>

                    <VerticalStackLayout
                        x:Name="ResultButtons"
                        IsVisible="False"
                        Spacing="12"
                        HorizontalOptions="Center">

                        <HorizontalStackLayout Spacing="10">

                            <Button Text="Less" Clicked="OnLessClicked" BackgroundColor="Gray" />
                            <Button Text="Same" Clicked="OnSameClicked" BackgroundColor="Blue" TextColor="White" />
                            <Button Text="More" Clicked="OnMoreClicked" BackgroundColor="Green" TextColor="White" />

                        </HorizontalStackLayout>

                        <Button Text="End Game"
                                Clicked="OnEndGameClicked"
                                BackgroundColor="Red"
                                TextColor="White"
                                WidthRequest="250" />

                    </VerticalStackLayout>

                </Grid>

            </Grid>

        </ScrollView>

    </Grid>

</ContentPage>