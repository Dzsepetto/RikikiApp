<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RikikiApp.Views.ProfileView"
             Loaded="OnLoaded">

    <VerticalStackLayout Padding="20" Spacing="10">

        <Label Text="{Binding NeedsToLoginTxt}" TextColor="Red"/>

        <Label Text="Your Players"
           FontSize="24"
           HorizontalOptions="Center" />

        <!-- Input -->
        <Grid ColumnDefinitions="*, Auto">
            <Entry Text="{Binding NewPlayerName}"
               Placeholder="Enter player name"
               Grid.Column="0" />

            <Button Text="Add"
            Command="{Binding AddPlayerCommand}"
            Grid.Column="1" />
        </Grid>

        <!-- List -->
        <CollectionView ItemsSource="{Binding Players}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10" Margin="5">
                        <Label Text="{Binding Name}" FontSize="18"/>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentView>