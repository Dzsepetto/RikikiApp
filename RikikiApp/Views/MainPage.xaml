<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RikikiApp.Views.MainPage">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <VerticalStackLayout Grid.Row="0" Padding="30" VerticalOptions="Center" Spacing="30">

            <Button Text="Games" Clicked="OpenGamesView" HorizontalOptions="Fill"  MinimumHeightRequest="100"/>
            <Button Text="DB test" Clicked="OnDbTestClicked" MinimumHeightRequest="100" />

        </VerticalStackLayout>
    </Grid>

</ContentPage>

    