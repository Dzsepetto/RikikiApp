<mct:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui"
    x:Class="RikikiApp.Views.Popups.AddPlayerPopup">

    <Grid VerticalOptions="Center" HorizontalOptions="Center"
          WidthRequest="320">

        <VerticalStackLayout Padding="10" Spacing="12">
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">

                <Label Text="Select" VerticalOptions="Center"/>

                <Switch IsToggled="{Binding IsAddMode}" />

                <Label Text="Add new" VerticalOptions="Center"/>

            </HorizontalStackLayout>
            <Label Text="Select or add player"
                   FontAttributes="Bold"
                   FontSize="20"
                   HorizontalOptions="Center"/>
            <Entry Placeholder="Search players"
       Text="{Binding SearchText}"
       IsVisible="{Binding IsAddMode, Converter={StaticResource InverseBoolConverter}}" />
            <!-- LISTA -->
            <CollectionView 
    ItemsSource="{Binding Players}"
    HeightRequest="180"
    IsVisible="{Binding IsAddMode, Converter={StaticResource InverseBoolConverter}}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border 
        BackgroundColor="#1E1E1E"
        Stroke="#3A3A3A"
        StrokeThickness="1"
        StrokeShape="RoundRectangle 12"
        Padding="0"
        Margin="0,0,0,10">

                            <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="10"
              VerticalOptions="Center">

                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                    Command="{Binding Source={RelativeSource AncestorType={x:Type mct:Popup}}, Path=BindingContext.TogglePlayerCommand}"
                    CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>

                                <CheckBox 
                Grid.Column="0"
                IsChecked="{Binding IsSelected}"
                VerticalOptions="Center"/>

                                <Label 
                Grid.Column="1"
                Text="{Binding Name}"
                TextColor="White"
                VerticalOptions="Center"
                FontSize="16" HorizontalOptions="Center"/>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

            <!-- ÚJ -->
            <Entry 
    Placeholder="New player name"
    Text="{Binding NewPlayerName}"
    IsVisible="{Binding IsAddMode}" />

            <HorizontalStackLayout Spacing="12"
                                   HorizontalOptions="Center">

                <Button Text="Cancel"
                        Command="{Binding CancelCommand}" />

                <Button Text="Add"
                Clicked="TestClick"
                Command="{Binding AddCommand}" />

            </HorizontalStackLayout>

        </VerticalStackLayout>

    </Grid>
</mct:Popup>