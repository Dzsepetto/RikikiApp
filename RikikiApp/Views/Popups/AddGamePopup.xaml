<?xml version="1.0" encoding="utf-8" ?>
<mct:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mct="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui"
             x:Class="RikikiApp.Views.Popups.AddGamePopup"
             >
    <Grid VerticalOptions="Center" HorizontalOptions="Center" WidthRequest="320" MaximumWidthRequest="400" Margin="0">

        <VerticalStackLayout Spacing="16" Padding="20">

            <Label Text="Add Game" FontAttributes="Bold" FontSize="22" HorizontalOptions="Center"/>

            <Entry  Text="{Binding GameName}" Placeholder="Game name" FontSize="16" HeightRequest="45"/>


            <Label Text="Scoring version" FontAttributes="Bold" />
            <Picker ItemsSource="{Binding ScoringTypes}" SelectedItem="{Binding SelectedScoringType}" />

            <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">



                <Button Text="Cancel"
        Command="{Binding CancelCommand}" />
                <Button Text="Save"
        Command="{Binding SaveCommand}" />

            </HorizontalStackLayout>

        </VerticalStackLayout>

    </Grid>
 </mct:Popup>