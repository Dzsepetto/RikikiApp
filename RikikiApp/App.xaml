<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:RikikiApp.Converters"
             x:Class="RikikiApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="PrimaryGreen">#007008</Color>
            <Color x:Key="AccentGreen">#00A010</Color>
            <Color x:Key="CardBg">#FFFFFF</Color>
            <Color x:Key="DeleteColor">#B00020</Color>

            
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
               
            </ResourceDictionary.MergedDictionaries>
            
            <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
