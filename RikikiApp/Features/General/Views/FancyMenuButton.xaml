<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="RikikiApp.Features.General.Views.FancyMenuButton"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="Root">

    <Grid HeightRequest="78" Padding="0">
        <Border
            BackgroundColor="#2A2430"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 18"
            Padding="0"
            Margin="0,10,0,0">

            <Grid>
                <Label
                    Text="{Binding Title, Source={x:Reference Root}}"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Margin="0,10,0,0"
                    TextColor="White"
                    FontSize="20"
                    FontAttributes="Bold" />
            </Grid>
        </Border>

        <Image
            Source="{Binding Icon, Source={x:Reference Root}}"
            WidthRequest="58"
            HeightRequest="58"
            HorizontalOptions="End"
            VerticalOptions="Start"
            TranslationX="6"
            TranslationY="-2"
            Aspect="AspectFit" />

        <Grid.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnTapped" />
        </Grid.GestureRecognizers>
    </Grid>
</ContentView>