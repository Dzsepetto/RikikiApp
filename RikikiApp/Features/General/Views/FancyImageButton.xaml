<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RikikiApp.Features.General.Views.FancyImageButton"
             x:Name="Root">

    <Grid>
        <Image x:Name="BtnImage"
               Source="{Binding Source, Source={x:Reference Root}}"
               Aspect="{Binding Aspect, Source={x:Reference Root}}"
               HorizontalOptions="Fill"
               VerticalOptions="Fill"/>

        <Grid.GestureRecognizers>

            <TapGestureRecognizer 
                Command="{Binding Command, Source={x:Reference Root}}"
                CommandParameter="{Binding CommandParameter, Source={x:Reference Root}}" />

            <PointerGestureRecognizer
                PointerPressed="OnPressed"
                PointerReleased="OnReleased"
                PointerExited="OnReleased"/>

        </Grid.GestureRecognizers>

    </Grid>
    
</ContentView>
