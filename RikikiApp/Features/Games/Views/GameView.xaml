<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:RikikiApp.Converters"
             x:Class="RikikiApp.Features.Games.Views.GameView"
             x:Name="Root">

    <ContentView.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColor" />
    </ContentView.Resources>

        <Grid Padding="16" RowDefinitions="Auto,*">

            <!-- HEADER -->
            <Grid ColumnDefinitions="Auto,*,Auto"
              VerticalOptions="Center"
              Margin="0,0,0,10">

                <Button Text="←"
                    Grid.Column="0"
                    Command="{Binding BackCommand}"
                    BackgroundColor="{StaticResource AccentGreen}"
                    TextColor="White"
                    FontSize="20"
                    CornerRadius="20"/>
                
                <Label Text="Games"
                   Grid.Column="1"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="White" />

                <Button Text="+"
                    Grid.Column="2"
                    Command="{Binding NewGameCommand}"
                    BackgroundColor="{StaticResource AccentGreen}"
                    TextColor="White"
                    CornerRadius="20"
                    WidthRequest="40"
                    HeightRequest="40"/>
            </Grid>

            <!-- CONTENT -->
            <VerticalStackLayout Grid.Row="1" Spacing="14">

                <!-- FILTERS -->
                <Label Text="Filters"
                   TextColor="White"
                   Opacity="0.8"/>

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">

                <Border Grid.Column="0"
                        BackgroundColor="{Binding IsSetupSelected, Converter={StaticResource BoolToColor}}"
                        StrokeShape="RoundRectangle 12"
                        Padding="10">

                    <Label Text="Setup"
                           HorizontalOptions="Center"
                           TextColor="White">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleSetupCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Border>

                <Border Grid.Column="1"
                        BackgroundColor="{Binding IsInProgressSelected, Converter={StaticResource BoolToColor}}"
                        StrokeShape="RoundRectangle 12"
                        Padding="10">

                        <Label Text="In Progress"
                           HorizontalOptions="Center"
                           TextColor="White">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleInProgressCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border Grid.Column="2"
                        BackgroundColor="{Binding IsFinishedSelected, Converter={StaticResource BoolToColor}}"
                        StrokeShape="RoundRectangle 12"
                        Padding="10">

                        <Label Text="Finished"
                           HorizontalOptions="Center"
                           TextColor="White">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleFinishedCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                </Grid>

                <!-- LIST -->
                <CollectionView ItemsSource="{Binding Games}" SelectionMode="None">

                    <CollectionView.EmptyView>
                        <Label Text="No games yet. Tap + to create one."
                           TextColor="White"
                           Opacity="0.6"
                           HorizontalOptions="Center"/>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>

                            <!-- CARD -->
                            <Border BackgroundColor="White"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 16"
                                Padding="14"
                                Margin="0,6"
                                Shadow="0,4,10,#00000033">

                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">

                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Name}"
                                           FontAttributes="Bold"
                                           FontSize="16"
                                           TextColor="#222"/>

                                        <Label Text="{Binding Status}"
                                           FontSize="12"
                                           TextColor="#666"/>
                                    </VerticalStackLayout>

                                    <!-- OPEN BUTTON -->
                                    <Border Grid.Column="1"
                                        BackgroundColor="{StaticResource AccentGreen}"
                                        StrokeShape="RoundRectangle 10"
                                        Padding="10,6">

                                        <Label Text="Open"
                                           TextColor="White"
                                           FontAttributes="Bold">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer
                                                Command="{Binding Source={x:Reference Root}, Path=BindingContext.OpenGameCommand}"
                                                CommandParameter="{Binding Id}"/>
                                            </Label.GestureRecognizers>
                                        </Label>

                                    </Border>

                                </Grid>

                            </Border>

                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>

            </VerticalStackLayout>

        </Grid>
    </ContentView>