<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="RikikiApp.Features.Games.Views.GamePlayView">

    <Grid Padding="16"
          RowDefinitions="Auto,*"
          BackgroundColor="{StaticResource PrimaryGreen}">

        <!-- HEADER -->
        <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,10">

            <Button Text="←"
                    Command="{Binding BackCommand}"
                    BackgroundColor="{StaticResource AccentGreen}"
                    TextColor="White"
                    FontSize="20"/>

            <Label Grid.Column="1"
                   Text="{Binding RoundText}"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center"/>
        </Grid>

        <ScrollView Grid.Row="1">

            <VerticalStackLayout Spacing="16">

                <!-- GAME CARD -->
                <Border BackgroundColor="{StaticResource CardBg}"
                        StrokeShape="RoundRectangle 16"
                        Padding="14"
                        IsVisible="{Binding IsGameVisible}"
                        Shadow="0,4,10,#00000033">

                    <CollectionView ItemsSource="{Binding Calls}"
                                    SelectionMode="None">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>

                                <Grid ColumnDefinitions="*,Auto,Auto"
                                      Padding="8"
                                      ColumnSpacing="12">

                                    <!-- NAME -->
                                    <Label Text="{Binding PlayerName}"
                                           VerticalOptions="Center"
                                           FontAttributes="Bold"
                                           FontSize="16"
                                           TextColor="#222"/>

                                    <!-- CALL -->
                                    <HorizontalStackLayout Grid.Column="1"
                                                           Spacing="6"
                                                           VerticalOptions="Center">

                                        <Border BackgroundColor="#EEE"
                                                StrokeShape="RoundRectangle 10"
                                                Padding="6">
                                            <Label Text="−">
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding DecreaseCallCommand}"/>
                                                </Label.GestureRecognizers>
                                            </Label>
                                        </Border>

                                        <Label Text="{Binding Called}"
                                               WidthRequest="30"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"
                                               FontSize="18"
                                               FontAttributes="Bold"/>

                                        <Border BackgroundColor="{StaticResource AccentGreen}"
                                                StrokeShape="RoundRectangle 10"
                                                Padding="6">
                                            <Label Text="+"
                                                   TextColor="White">
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding IncreaseCallCommand}"/>
                                                </Label.GestureRecognizers>
                                            </Label>
                                        </Border>

                                    </HorizontalStackLayout>

                                    <!-- WON -->
                                    <HorizontalStackLayout Grid.Column="2"
                                                           Spacing="6"
                                                           VerticalOptions="Center"
                                                           IsVisible="{Binding IsWonVisible}">

                                        <Border BackgroundColor="#EEE"
                                                StrokeShape="RoundRectangle 10"
                                                Padding="6">
                                            <Label Text="−">
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding DecreaseWonCommand}"/>
                                                </Label.GestureRecognizers>
                                            </Label>
                                        </Border>

                                        <Label Text="{Binding Won}"
                                               WidthRequest="30"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"
                                               FontSize="18"
                                               FontAttributes="Bold"/>

                                        <Border BackgroundColor="{StaticResource AccentGreen}"
                                                StrokeShape="RoundRectangle 10"
                                                Padding="6">
                                            <Label Text="+"
                                                   TextColor="White">
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding IncreaseWonCommand}"/>
                                                </Label.GestureRecognizers>
                                            </Label>
                                        </Border>

                                    </HorizontalStackLayout>

                                </Grid>

                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>
                </Border>

                <!-- RESULTS CARD (KÖZÉPEN!) -->
                <Border BackgroundColor="{StaticResource CardBg}"
                        StrokeShape="RoundRectangle 16"
                        Padding="16"
                        IsVisible="{Binding IsResultVisible}"
                        HorizontalOptions="Center"
                        WidthRequest="300"
                        Shadow="0,4,10,#00000033">

                    <CollectionView ItemsSource="{Binding Results}"
                                    SelectionMode="None">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>

                                <Grid ColumnDefinitions="*,50,50,60"
                                      Padding="6">

                                    <Label Text="{Binding PlayerName}"
                                           HorizontalTextAlignment="Start"/>

                                    <Label Grid.Column="1"
                                           Text="{Binding Called}"
                                           HorizontalTextAlignment="Center"/>

                                    <Label Grid.Column="2"
                                           Text="{Binding Won}"
                                           HorizontalTextAlignment="Center"/>

                                    <Label Grid.Column="3"
                                           Text="{Binding Score}"
                                           HorizontalTextAlignment="Center"
                                           FontAttributes="Bold"/>

                                </Grid>

                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </Border>

                <!-- ACTIONS -->
                <VerticalStackLayout Spacing="12">

                    <Border BackgroundColor="{StaticResource AccentGreen}"
                            StrokeShape="RoundRectangle 12"
                            Padding="14"
                            IsVisible="{Binding IsFixCallsVisible}">
                        <Label Text="Fix Calls"
                               TextColor="White"
                               HorizontalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding FixCallsCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="#444"
                            StrokeShape="RoundRectangle 12"
                            Padding="14"
                            IsVisible="{Binding IsEndRoundVisible}">
                        <Label Text="End Round"
                               TextColor="White"
                               HorizontalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding EndRoundCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <!-- ROUND RESULT ACTIONS -->
                    <HorizontalStackLayout IsVisible="{Binding IsResultVisible}"
                                           HorizontalOptions="Center"
                                           Spacing="16">

                        <Border BackgroundColor="#B00020"
                                StrokeShape="RoundRectangle 12"
                                Padding="12"
                                WidthRequest="80">
                            <Label Text="Less"
                                   TextColor="White"
                                   HorizontalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding LessCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Border>

                        <Border BackgroundColor="#666"
                                StrokeShape="RoundRectangle 12"
                                Padding="12"
                                WidthRequest="80">
                            <Label Text="Same"
                                   TextColor="White"
                                   HorizontalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SameCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Border>

                        <Border BackgroundColor="{StaticResource AccentGreen}"
                                StrokeShape="RoundRectangle 12"
                                Padding="12"
                                WidthRequest="80">
                            <Label Text="More"
                                   TextColor="White"
                                   HorizontalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding MoreCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Border>

                    </HorizontalStackLayout>

                </VerticalStackLayout>

            </VerticalStackLayout>

        </ScrollView>

    </Grid>
</ContentView>