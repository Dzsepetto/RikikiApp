<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="RikikiApp.Features.Games.Views.GameSetupView"
             x:Name="Root">

    <ScrollView>
            <Grid Padding="16" RowDefinitions="Auto,*,Auto"
              BackgroundColor="{StaticResource PrimaryGreen}">

                <!-- HEADER -->
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,10">

                    <Button Text="←"
                        Command="{Binding BackCommand}"
                        BackgroundColor="{StaticResource AccentGreen}"
                        TextColor="White"
                        FontSize="20"/>

                    <Label Text="{Binding Title}"
                       Grid.Column="1"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="White"/>

                    <Button Text="🗑"
                        Grid.Column="2"
                        Command="{Binding DeleteGameCommand}"
                        BackgroundColor="{StaticResource DeleteColor}"
                        TextColor="White"/>
                </Grid>

                <!-- CONTENT -->
                <VerticalStackLayout Grid.Row="1" Spacing="16">

                    <!-- PLAYERS CARD -->
                    <Border BackgroundColor="{StaticResource CardBg}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        Padding="14"
                        Shadow="0,4,10,#00000033">

                        <toolkit:Expander IsExpanded="{Binding IsPlayersExpanded}" x:Name="PlayersExpander">

                            <!-- HEADER -->
                            <toolkit:Expander.Header>
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="{Binding PlayersTitle}"
                                       FontAttributes="Bold"
                                       FontSize="16"
                                       TextColor="#222"/>

                                    <Label Grid.Column="1" Text="▼">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label"
                                                     Binding="{Binding Source={x:Reference PlayersExpander}, Path=IsExpanded}"
                                                     Value="True">
                                                <Setter Property="Rotation" Value="180"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Grid>
                            </toolkit:Expander.Header>

                            <!-- LIST -->
                            <VerticalStackLayout Spacing="10">

                                <!-- EMPTY -->
                                <VerticalStackLayout IsVisible="{Binding IsEmpty}" Spacing="4" Padding="10">
                                    <Label Text="No players yet"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"/>
                                    <Label Text="Add players to start"
                                       FontSize="12"
                                       HorizontalOptions="Center"
                                       Opacity="0.6"/>
                                </VerticalStackLayout>

                                <!-- PLAYERS -->
                                <CollectionView x:Name="PlayersList"
                                            ItemsSource="{Binding Players}"
                                            IsVisible="{Binding IsNotEmpty}"
                                            SelectionMode="None"
                                            Margin="0,6">

                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>

                                            <Grid RowDefinitions="Auto,Auto"
                                              ColumnDefinitions="40,50,*,40"
                                              Padding="8">

                                                <!-- DROP INDICATOR -->
                                                <BoxView Grid.Row="0"
                                                     Grid.ColumnSpan="4"
                                                     HeightRequest="3"
                                                     BackgroundColor="{StaticResource AccentGreen}"
                                                     IsVisible="{Binding IsDropTarget}" />

                                                <Grid Grid.Row="1"
                                                  Grid.ColumnSpan="4"
                                                  ColumnDefinitions="40,50,*,40">

                                                    <Grid.GestureRecognizers>
                                                        <DropGestureRecognizer Drop="OnDrop"
                                                                           DragOver="OnDragOver"
                                                                           AllowDrop="True"/>
                                                    </Grid.GestureRecognizers>

                                                    <!-- DRAG -->
                                                    <Label Grid.Column="0"
                                                       Text="☰"
                                                       FontSize="18"
                                                       VerticalOptions="Center"
                                                       HorizontalOptions="Center">
                                                        <Label.GestureRecognizers>
                                                            <DragGestureRecognizer DragStarting="OnDragStarting"/>
                                                        </Label.GestureRecognizers>
                                                    </Label>

                                                    <!-- SEAT -->
                                                    <Border Grid.Column="1"
                                                        BackgroundColor="#F2F2F2"
                                                        Padding="6"
                                                        StrokeShape="RoundRectangle 10">
                                                        <Label Text="{Binding SeatOrder}"
                                                           HorizontalOptions="Center"/>
                                                    </Border>

                                                    <!-- NAME -->
                                                    <Label Grid.Column="2"
                                                       Text="{Binding GuestName}"
                                                       VerticalOptions="Center"
                                                       LineBreakMode="TailTruncation"
                                                       TextColor="#222"/>

                                                    <!-- DELETE -->
                                                    <Label Grid.Column="3"
                                                       Text="🗑"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center">
                                                        <Label.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                            Command="{Binding Source={x:Reference Root}, Path=BindingContext.DeletePlayerCommand}"
                                                            CommandParameter="{Binding .}"/>
                                                        </Label.GestureRecognizers>
                                                    </Label>

                                                </Grid>
                                            </Grid>

                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>

                                    <!-- DROP TO END -->
                                    <CollectionView.Footer>
                                        <Grid HeightRequest="40">
                                            <Grid.GestureRecognizers>
                                                <DropGestureRecognizer Drop="OnDropToEnd" AllowDrop="True"/>
                                            </Grid.GestureRecognizers>

                                            <BoxView HeightRequest="3"
                                                 BackgroundColor="{StaticResource AccentGreen}"
                                                 VerticalOptions="Start"
                                                 IsVisible="{Binding Source={x:Reference Root}, Path=BindingContext.IsDragging}" />
                                        </Grid>
                                    </CollectionView.Footer>

                                </CollectionView>

                            </VerticalStackLayout>

                        </toolkit:Expander>

                    </Border>

                    <!-- ACTION BUTTONS -->
                    <Grid RowDefinitions="*,*" RowSpacing="10">

                        <Border BackgroundColor="{StaticResource AccentGreen}"
                            StrokeShape="RoundRectangle 12"
                            Padding="12"
                            Grid.Row="0">
                            <Label Text="+ Add player"
                               TextColor="White"
                               HorizontalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding AddPlayerCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Border>

                        <Border BackgroundColor="#444"
                            StrokeShape="RoundRectangle 12"
                            Padding="12"
                            Grid.Row="1">
                            <Label Text="Stats"
                               TextColor="White"
                               HorizontalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ShowStatsCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Border>

                    </Grid>

                </VerticalStackLayout>

                <!-- BOTTOM -->
            <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,16,0,0">
                <Button
                    Grid.Column="0"
                        Text="End game"
                        Command="{Binding EndGameCommand}"
                        BackgroundColor="{StaticResource DeleteColor}"
                        TextColor="White"
                        CornerRadius="12"/>
                <Button
                    Grid.Column="1"
                        Text="Start game"
                        Command="{Binding StartGameCommand}"
                        BackgroundColor="{StaticResource AccentGreen}"
                        TextColor="White"
                        CornerRadius="12"/>

            </Grid>

            </Grid>
        </ScrollView>
    </ContentView>