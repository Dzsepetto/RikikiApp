<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="RikikiApp.Features.Games.Views.GameSetupView"
             x:Name="Root">

    <ScrollView>
        <Grid Padding="12" RowDefinitions="Auto,*,Auto">

            <!-- TOP BAR -->
            <Grid ColumnDefinitions="Auto,*,Auto" Row="0">
                <Button Text="← Back" Command="{Binding BackCommand}" />

                <Label Text="{Binding Title}"
                       Grid.Column="1"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       FontSize="18"
                       FontAttributes="Bold" />

                <Button Text="🗑" Grid.Column="2" Command="{Binding DeleteGameCommand}" />
            </Grid>

            <!-- CONTENT -->
            <VerticalStackLayout Grid.Row="1" Spacing="14" Padding="0,16,0,0">
                <toolkit:Expander IsExpanded="{Binding IsPlayersExpanded}" x:Name="PlayersExpander">

                    <!-- HEADER -->
                    <toolkit:Expander.Header>
                        <Grid ColumnDefinitions="*,Auto" Padding="0,0,0,6">
                            <Label Text="{Binding PlayersTitle}" FontAttributes="Bold" FontSize="16" />
                            <Label Grid.Column="1" Text="▼">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding Source={x:Reference PlayersExpander}, Path=IsExpanded}"
                                                 Value="True">
                                        <Setter Property="Rotation" Value="180"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Grid>
                    </toolkit:Expander.Header>

                    <!-- LENYÍLÓ TARTALOM -->
                    <VerticalStackLayout Spacing="14">

                        <VerticalStackLayout Spacing="10">

                            <!-- EMPTY STATE -->
                            <VerticalStackLayout IsVisible="{Binding IsEmpty}" Spacing="6" Padding="10">
                                <Label Text="No players yet" FontAttributes="Bold" HorizontalOptions="Center" />
                                <Label Text="Add players to start the game"
                                       FontSize="12"
                                       HorizontalOptions="Center"
                                       Opacity="0.7" />
                            </VerticalStackLayout>

                            <!-- ✅ LISTA (CollectionView-re cserélve) -->
                            <CollectionView x:Name="PlayersList"
                                            ItemsSource="{Binding Players}"
                                            IsVisible="{Binding IsNotEmpty}"
                                            SelectionMode="None"
                                            HeightRequest="300"
                                            Margin="0,6">

                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="40,50,*,50" Padding="8">
                                            <BoxView Grid.Row="0" Grid.ColumnSpan="4" HeightRequest="3" BackgroundColor="Blue" IsVisible="{Binding IsDropTarget}" />
                                            <Grid Grid.Row="1" Grid.ColumnSpan="4" ColumnDefinitions="40,50,*,50">
                                                <Grid.GestureRecognizers>
                                                    <DropGestureRecognizer Drop="OnDrop" DragOver="OnDragOver" AllowDrop="True"/>
                                                </Grid.GestureRecognizers>

                                                <!-- DRAG -->
                                                <Label Grid.Column="0" Text="☰" FontSize="18" VerticalOptions="Center" HorizontalOptions="Center">
                                                    <Label.GestureRecognizers>
                                                        <DragGestureRecognizer DragStarting="OnDragStarting"/>
                                                    </Label.GestureRecognizers>
                                                </Label>

                                                <!-- SEAT -->
                                                <Border Grid.Column="1" BackgroundColor="#E8E8E8" Padding="6">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="10"/>
                                                    </Border.StrokeShape>
                                                    <Label Text="{Binding SeatOrder}" HorizontalOptions="Center"/>
                                                </Border>

                                                <!-- NAME -->
                                                <Label Grid.Column="2" Text="{Binding GuestName}" VerticalOptions="Center" LineBreakMode="TailTruncation"/>

                                                <!-- DELETE -->
                                                <Button Grid.Column="3" Text="🗑" BackgroundColor="Transparent" Command="{Binding Source={x:Reference Root}, Path=BindingContext.DeletePlayerCommand}" CommandParameter="{Binding .}" />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>

                                <CollectionView.Footer>
                                    <Grid HeightRequest="60">
                                        <Grid.GestureRecognizers>
                                            <DropGestureRecognizer Drop="OnDropToEnd" AllowDrop="True"/>
                                        </Grid.GestureRecognizers>

                                        <BoxView HeightRequest="3" BackgroundColor="Blue" VerticalOptions="Start" IsVisible="{Binding Source={x:Reference Root}, Path=BindingContext.IsDragging}" />
                                    </Grid>
                                </CollectionView.Footer>

                            </CollectionView>

                        </VerticalStackLayout>
                    </VerticalStackLayout>

                </toolkit:Expander>

                <Button Text="+ Add player" Command="{Binding AddPlayerCommand}" />
                <Button Text="Show Stats" Command="{Binding ShowStatsCommand}" />

            </VerticalStackLayout>

            <!-- BOTTOM BUTTONS -->
            <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,12,0,0">

                <Button Grid.Column="0"
                        Text="End game"
                        BackgroundColor="Red"
                        TextColor="White"
                        Command="{Binding EndGameCommand}"/>

                <Button Grid.Column="1"
                        Text="Start game"
                        BackgroundColor="Green"
                        Command="{Binding StartGameCommand}" />

            </Grid>

        </Grid>
    </ScrollView>
</ContentView>