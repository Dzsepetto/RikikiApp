<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RikikiApp.Features.Profile.Views.Components.ManagePlayersView">
    
    <VerticalStackLayout Padding="20" Spacing="10">
        <Button Text="Back" Command="{Binding BackCommand}"></Button>

        <Label Text="Your Players" FontSize="24" HorizontalOptions="Center" />

        <!-- Input -->
        <Grid ColumnDefinitions="*, Auto">
            <Entry Text="{Binding NewPlayerName}" Placeholder="Enter player name" Grid.Column="0" />

            <Button Text="Add" Command="{Binding AddPlayerCommand}" Grid.Column="1" />
        </Grid>
    
        <!-- List -->
        <CollectionView ItemsSource="{Binding Players}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10" Margin="5">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="{Binding Name}" FontSize="18" />

                            <Button Grid.Column="1" Text="Delete" Command="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=BindingContext.DeletePlayerCommand}" CommandParameter="{Binding .}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>

</ContentView>
