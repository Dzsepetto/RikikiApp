<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:RikikiApp.Features.General.Views"
             x:Class="RikikiApp.Features.Main.Views.MainView">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <VerticalStackLayout Grid.Row="0"
                             Padding="30"
                             VerticalOptions="Center"
                             Spacing="30">
            <Label FontSize="34">Welcome to Rikiki Kings</Label>

            <controls:FancyImageButton
    Source="btn_games_main.png"
    Command="{Binding OpenGamesViewCommand}"
    HeightRequest="200"/>

            <Button Text="DB test"
                    Command="{Binding DbTestCommand}"
                    HeightRequest="100"/>
        </VerticalStackLayout>
    </Grid>

</ContentView>