<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RikikiApp.Features.Main.Views.MainLayoutPage"
             xmlns:controls="clr-namespace:RikikiApp.Features.General.Views"
             Title="MainLayoutPage">

    <Grid RowDefinitions="*,Auto" BackgroundColor="#007008">

        <!-- CONTENT -->
        <ContentPresenter x:Name="PageContent" Grid.Row="0"/>

        <!-- CUSTOM TAB BAR -->
        <Grid Grid.Row="1"
      HeightRequest="100"
      ColumnDefinitions="*,*,*"
      ColumnSpacing="10">

            <Image
        Source="pokerboard.png"
        Aspect="Fill"
        Grid.ColumnSpan="3"
        ZIndex="0"/>

            <!-- PROFILE -->
            <controls:FancyMenuButton
    x:Name="ProfileButton"
    Grid.Column="0"
    Icon="btn_profile.png"
    Command="{Binding GoProfileCommand}" />

            <controls:FancyMenuButton
    x:Name="HomeButton"
    Grid.Column="1"
    Icon="btn_home.png"
    Command="{Binding GoHomeCommand}" />

            <controls:FancyMenuButton
    x:Name="StatsButton"
    Grid.Column="2"
    Icon="btn_stats.png"
    Command="{Binding GoStatsCommand}" />

        </Grid>

    </Grid>
</ContentPage>