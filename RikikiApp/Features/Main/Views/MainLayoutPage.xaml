<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RikikiApp.Features.Main.Views.MainLayoutPage"
             xmlns:controls="clr-namespace:RikikiApp.Features.General.Views"
             Title="MainLayoutPage">

    <Grid RowDefinitions="*,Auto">

        <!-- CONTENT -->
        <ContentPresenter x:Name="PageContent" Grid.Row="0"/>

        <!-- CUSTOM TAB BAR -->
        <Grid Grid.Row="1"
              BackgroundColor="#007008"
              HeightRequest="100"
              ColumnDefinitions="*,*,*"
              Padding="10"
              ColumnSpacing="20">

            <!-- Profile -->
            <Button BackgroundColor="#ffffff" TextColor="#000000" x:Name="ProfileButton" Grid.Column="0" Text="Profile" Clicked="GoProfile"/>
            
            <!-- Home -->
            <controls:FancyMenuButton
                x:Name="HomeButton"
                Grid.Column="1"
                Title="HOME"
                Icon="cards_icon.png"
                Clicked="GoHome"/>
            <!-- Stats -->
            <Button BackgroundColor="#ffffff" TextColor="#000000" x:Name="StatsButton" Grid.Column="2" Text="Stats" Clicked="GoStats"/>

        </Grid>

    </Grid>

</ContentPage>